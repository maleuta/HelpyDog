@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetString("UserId");
    var userRole = Context.Session.GetString("UserRole");
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HelpyDog</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #fdf6d6; }
        .navbar { box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        .card { border-radius: 15px; border: none; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-4" style="background-color: #7f54cf;">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">🐾 HelpyDog</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    
                    <ul class="navbar-nav flex-grow-1">
                        @if (!string.IsNullOrEmpty(userId))
                        {
                            <li class="nav-item"><a class="nav-link text-white" asp-controller="Home" asp-action="Index">Mój Piesek</a></li>
                            <li class="nav-item"><a class="nav-link text-white" asp-controller="Home" asp-action="Leaderboard">Ranking</a></li>
                            <li class="nav-item"><a class="nav-link text-white" asp-controller="Home" asp-action="WeeklyStats">Statystyki tygodnia</a></li>
                            
                            <li class="nav-item"><a class="nav-link text-white" asp-controller="Habits" asp-action="Index">Kategorie (Nawyki)</a></li>
                            <li class="nav-item"><a class="nav-link text-white" asp-controller="ShopItems" asp-action="Index">Sklep</a></li>
                            
                            @if (userRole == "Admin")
                            {
                                <li class="nav-item"><a class="nav-link text-warning fw-bold ms-3" asp-controller="Admin" asp-action="Index">Panel Admina</a></li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (string.IsNullOrEmpty(userId))
                        {
                            <li class="nav-item"><a class="nav-link text-white" asp-controller="Account" asp-action="Login">Logowanie</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link text-white btn btn-danger btn-sm px-3 mt-1" asp-controller="Account" asp-action="Logout">Wyloguj</a></li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>